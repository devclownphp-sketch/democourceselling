generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum MetricType {
    VISIT
    ENROLL
    CONTACT
}

model Admin {
    id                String         @id @default(cuid())
    username          String         @unique
    passwordHash      String
    createdByUsername String?
    createdAt         DateTime       @default(now())
    updatedAt         DateTime       @updatedAt
    sessions          AdminSession[]
    courses           Course[]
    reviews           Review[]
    quizzes           Quiz[]
    blogs             Blog[]
}

model AdminSession {
    id        String   @id @default(cuid())
    tokenHash String   @unique
    expiresAt DateTime
    createdAt DateTime @default(now())
    adminId   String
    admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

    @@index([adminId])
    @@index([expiresAt])
}

model Course {
    id                String        @id @default(cuid())
    title             String
    slug              String        @unique
    rating            Float         @default(4.5)
    courseImage       String        @default("")
    discountPercent   Float         @default(0)
    shortDescription  String
    whatIs            String
    whoCanJoin        String
    syllabusTopics    String
    studyPlan         String
    jobsAfter         String
    startLearningText String
    originalPrice     Decimal       @db.Decimal(10, 2)
    offerPrice        Decimal       @db.Decimal(10, 2)
    duration          String
    level             String
    classType         String
    liveQna           String
    pdfNotes          String
    callSupport       String
    lifetimeAccess    Boolean       @default(true)
    socialPrompt      String
    whatsappNumber    String
    enrollClicks      Int           @default(0)
    isActive          Boolean       @default(true)
    createdAt         DateTime      @default(now())
    updatedAt         DateTime      @updatedAt
    adminId           String?
    courseTypeId      String?
    admin             Admin?        @relation(fields: [adminId], references: [id], onDelete: SetNull)
    courseType        CourseType?   @relation(fields: [courseTypeId], references: [id], onDelete: SetNull)
    metricEvents      MetricEvent[]
    driveFolders      DriveFolder[]

    @@index([isActive])
    @@index([createdAt])
}

model CourseType {
    id        String   @id @default(cuid())
    name      String   @unique
    sortOrder Int      @default(0)
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    courses   Course[]

    @@index([sortOrder])
    @@index([isActive])
}

model Review {
    id         String   @id @default(cuid())
    name       String
    role       String   @default("Student")
    reviewText String
    rating     Int      @default(5)
    sortOrder  Int      @default(0)
    isActive   Boolean  @default(true)
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt
    adminId    String?
    admin      Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

    @@index([isActive])
    @@index([sortOrder])
    @@index([createdAt])
}

model ContactSubmission {
    id        String   @id @default(cuid())
    name      String
    email     String
    phone     String
    message   String
    createdAt DateTime @default(now())

    @@index([createdAt])
}

model MetricEvent {
    id        String     @id @default(cuid())
    type      MetricType
    path      String?
    ipAddress String?
    userAgent String?
    createdAt DateTime   @default(now())
    courseId  String?
    course    Course?    @relation(fields: [courseId], references: [id], onDelete: SetNull)

    @@index([type, createdAt])
    @@index([courseId])
}

model Quiz {
    id        String         @id @default(cuid())
    title     String
    heading   String
    slug      String         @unique
    category  String         @default("General")
    minutes   Int            @default(10)
    rating    Float          @default(4.5)
    sortOrder Int            @default(0)
    isActive  Boolean        @default(true)
    createdAt DateTime       @default(now())
    updatedAt DateTime       @updatedAt
    adminId   String?
    admin     Admin?         @relation(fields: [adminId], references: [id], onDelete: SetNull)
    questions QuizQuestion[]

    @@index([isActive])
    @@index([sortOrder])
    @@index([createdAt])
}

model QuizQuestion {
    id           String   @id @default(cuid())
    quizId       String
    quiz         Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
    questionText String
    options      String[]
    correctIndex Int      @default(0)
    sortOrder    Int      @default(0)
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    @@index([quizId])
    @@index([sortOrder])
}

model Blog {
    id            String   @id @default(cuid())
    title         String
    slug          String   @unique
    excerpt       String
    content       String
    featuredImage String   @default("")
    isPublished   Boolean  @default(false)
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    adminId       String?
    admin         Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

    @@index([isPublished])
    @@index([createdAt])
}

model DriveFolder {
    id         Int      @id @default(autoincrement())
    courseId   String
    folderName String
    folderId   String
    createdAt  DateTime @default(now())

    course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model BusinessProfile {
    id              String   @id @default(cuid())
    key             String   @unique @default("primary")
    businessName    String   @default("STP Computer Education")
    supportEmail    String   @default("stpcomputereducation@gmail.com")
    supportPhone    String   @default("+91 9460824001")
    addressLine     String   @default("Mahipal Nagar, New Delhi - 110037")
    contactHeadline String   @default("Get in touch with us")
    contactSubtext  String   @default("For any queries about our courses, contact us using the details below.")
    mapEmbedUrl     String   @default("")
    twitterUrl      String   @default("")
    facebookUrl     String   @default("")
    instagramUrl    String   @default("")
    linkedinUrl     String   @default("")
    youtubeUrl      String   @default("")
    updatedAt       DateTime @updatedAt
    createdAt       DateTime @default(now())
}
