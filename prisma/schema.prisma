generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum MetricType {
    VISIT
    ENROLL
    CONTACT
}

model Admin {
    id                String         @id @default(cuid())
    username          String         @unique
    passwordHash      String
    createdByUsername String?
    createdAt         DateTime       @default(now())
    updatedAt         DateTime       @updatedAt
    sessions          AdminSession[]
    courses           Course[]
    reviews           Review[]
    quizzes           Quiz[]
    blogs             Blog[]
}

model AdminSession {
    id        String   @id @default(cuid())
    tokenHash String   @unique
    expiresAt DateTime
    createdAt DateTime @default(now())
    adminId   String
    admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

    @@index([adminId])
    @@index([expiresAt])
}

model Course {
    id                String        @id @default(cuid())
    courseUrlId       String?       @unique  // 5-char unique ID for URL (e.g., "ABC12")
    title             String
    slug              String        @unique
    rating            Float         @default(4.5)
    courseImage       String        @default("")
    discountPercent   Float         @default(0)
    shortDescription  String
    whatIs            String
    whoCanJoin        String
    syllabusTopics    String
    studyPlan         String
    jobsAfter         String
    startLearningText String
    originalPrice     Decimal       @db.Decimal(10, 2)
    offerPrice        Decimal       @db.Decimal(10, 2)
    duration          String
    level             String
    classType         String
    liveQna           String
    pdfNotes          String
    callSupport       String
    lifetimeAccess    Boolean       @default(true)
    socialPrompt      String
    whatsappNumber    String
    enrollClicks      Int           @default(0)
    isActive          Boolean       @default(true)
    createdAt         DateTime      @default(now())
    updatedAt         DateTime      @updatedAt
    adminId           String?
    courseTypeId      String?
    admin             Admin?        @relation(fields: [adminId], references: [id], onDelete: SetNull)
    courseType        CourseType?   @relation(fields: [courseTypeId], references: [id], onDelete: SetNull)
    metricEvents      MetricEvent[]
    driveFolders      DriveFolder[]
    pdfs              CoursePDF[]
    studyMaterials    StudyMaterial[]
    certificates      Certificate[]
    demoContent       Json?         @default("[]")
    certificateImage  String?
    totalHours        Float?

    @@index([isActive])
    @@index([createdAt])
}

model CourseType {
    id        String   @id @default(cuid())
    name      String   @unique
    icon      String   @default("book") // Icon name: book, code, chart, design, database, network, security, mobile, cloud, data
    color     String   @default("#6366f1") // Default accent color for this category
    sortOrder Int      @default(0)
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    courses   Course[]

    @@index([sortOrder])
    @@index([isActive])
}

model Review {
    id         String   @id @default(cuid())
    name       String
    role       String   @default("Student")
    reviewText String
    quote      String   @default("")
    avatar     String?  // Path to uploaded avatar image
    marqueeText String? // Short text for marquee (max 50 chars)
    rating     Int      @default(5)
    sortOrder  Int      @default(0)
    isFeatured Boolean  @default(false)
    isActive   Boolean  @default(true)
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt
    adminId    String?
    admin      Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

    @@index([isActive])
    @@index([isFeatured])
    @@index([sortOrder])
    @@index([createdAt])
}

model FAQ {
    id        String   @id @default(cuid())
    question  String
    answer    String
    sortOrder Int      @default(0)
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([isActive])
    @@index([sortOrder])
}

model Feature {
    id          String   @id @default(cuid())
    icon        String   @default("check") // Icon name
    title       String
    description String
    color       String   @default("#6366f1") // Accent color
    sortOrder   Int      @default(0)
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@index([isActive])
    @@index([sortOrder])
}

model MarqueeSettings {
    id                String @id @default("default")
    speed             Int    @default(30) // Seconds for one cycle (10-60)
    direction         String @default("ltr") // "ltr" or "rtl"
    isEnabled         Boolean @default(true)
    minReviewsForAuto Int    @default(3) // Minimum reviews needed to auto-enable marquee
    updatedAt         DateTime @updatedAt
    createdAt         DateTime @default(now())
}

model ContactSubmission {
    id        String   @id @default(cuid())
    name      String
    email     String
    phone     String
    message   String
    createdAt DateTime @default(now())

    @@index([createdAt])
}

model MetricEvent {
    id        String     @id @default(cuid())
    type      MetricType
    path      String?
    ipAddress String?
    userAgent String?
    createdAt DateTime   @default(now())
    courseId  String?
    course    Course?    @relation(fields: [courseId], references: [id], onDelete: SetNull)

    @@index([type, createdAt])
    @@index([courseId])
}

model Quiz {
    id        String         @id @default(cuid())
    title     String
    heading   String
    slug      String         @unique
    category  String         @default("General")
    minutes   Int            @default(10)
    rating    Float          @default(4.5)
    sortOrder Int            @default(0)
    isActive  Boolean        @default(true)
    createdAt DateTime       @default(now())
    updatedAt DateTime       @updatedAt
    adminId   String?
    admin     Admin?         @relation(fields: [adminId], references: [id], onDelete: SetNull)
    questions QuizQuestion[]

    @@index([isActive])
    @@index([sortOrder])
    @@index([createdAt])
}

model QuizQuestion {
    id           String   @id @default(cuid())
    quizId       String
    quiz         Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
    questionText String
    options      String[]
    correctIndex Int      @default(0)
    sortOrder    Int      @default(0)
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    @@index([quizId])
    @@index([sortOrder])
}

model Blog {
    id            String   @id @default(cuid())
    title         String
    slug          String   @unique
    excerpt       String
    content       String
    contentBlocks Json     @default("[]")
    featuredImage String   @default("")
    isPublished   Boolean  @default(false)
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    adminId       String?
    admin         Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

    @@index([isPublished])
    @@index([createdAt])
}

model DriveFolder {
    id         Int      @id @default(autoincrement())
    courseId   String
    folderName String
    folderId   String
    createdAt  DateTime @default(now())

    course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CoursePDF {
    id         Int      @id @default(autoincrement())
    courseId   String?  // Optional - allows PDFs without a course
    name       String
    url        String
    viewerType String   @default("embed")
    size       Int      @default(0)
    sortOrder  Int      @default(0)
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    course     Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)

    @@index([courseId])
    @@index([sortOrder])
}

model StudyMaterial {
    id          String   @id @default(cuid())
    title       String
    description String?
    category    String
    pdfUrl      String
    viewerType  String   @default("embed")
    thumbnail   String?
    sortOrder   Int      @default(0)
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    courseId    String?
    course      Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)

    categoryId  String?
    materialCategory StudyMaterialCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

    @@index([isActive])
    @@index([sortOrder])
    @@index([category])
}

model StudyMaterialCategory {
    id        String   @id @default(cuid())
    name      String   @unique
    icon      String   @default("book")
    color     String   @default("#6366f1")
    sortOrder Int      @default(0)
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    materials StudyMaterial[]

    @@index([sortOrder])
    @@index([isActive])
}

model CertificateTemplate {
    id        String   @id @default(cuid())
    name      String
    fileUrl   String
    fields    Json     // Array of { key, label, x, y, fontSize, color, width }
    isActive  Boolean  @default(false)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    certificates Certificate[]

    @@index([isActive])
}

model Certificate {
    id            String   @id @default(cuid())
    certificateId String   @unique // 7-letter uppercase random ID
    templateId    String
    studentName   String
    courseName    String
    courseId       String?
    regId         String   @unique
    startDate     DateTime
    endDate       DateTime
    duration      String
    issuedAt      DateTime @default(now())
    downloadUrl     String?
    termsAccepted   Boolean  @default(false)
    termsAcceptedAt DateTime?

    template    CertificateTemplate @relation(fields: [templateId], references: [id])
    course      Course?             @relation(fields: [courseId], references: [id], onDelete: SetNull)

    @@index([certificateId])
    @@index([regId])
    @@index([studentName])
}

model SubAdmin {
    id                String            @id @default(cuid())
    urlId             String?           @unique  // Random ID for URL (e.g., "ABC12")
    username          String            @unique
    passwordHash      String
    roleId            String?
    sessionTimeoutMin Int               @default(10)  // Default 10 minutes
    maxSessions       Int               @default(2)
    isActive          Boolean           @default(true)
    createdAt         DateTime          @default(now())
    updatedAt         DateTime          @updatedAt

    role              Role?             @relation(fields: [roleId], references: [id], onDelete: SetNull)
    sessions          SubAdminSession[]

    @@index([isActive])
}

model Role {
    id          String      @id @default(cuid())
    name        String      @unique
    permissions Json        // Array of permission strings
    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt

    subadmins   SubAdmin[]
}

model SubAdminSession {
    id         String   @id @default(cuid())
    subAdminId String
    tokenHash  String   @unique
    expiresAt  DateTime
    createdAt  DateTime @default(now())

    subAdmin   SubAdmin @relation(fields: [subAdminId], references: [id], onDelete: Cascade)

    @@index([subAdminId])
    @@index([expiresAt])
}

model BusinessProfile {
    id              String   @id @default(cuid())
    key             String   @unique @default("primary")
    businessName    String   @default("STP Computer Education")
    supportEmail    String   @default("stpcomputereducation@gmail.com")
    supportPhone    String   @default("+91 9460824001")
    addressLine     String   @default("Mahipal Nagar, New Delhi - 110037")
    contactHeadline String   @default("Get in touch with us")
    contactSubtext  String   @default("For any queries about our courses, contact us using the details below.")
    mapEmbedUrl     String   @default("")
    twitterUrl      String   @default("")
    facebookUrl     String   @default("")
    instagramUrl    String   @default("")
    linkedinUrl     String   @default("")
    youtubeUrl      String   @default("")
    updatedAt       DateTime @updatedAt
    createdAt       DateTime @default(now())
}

model SiteSettings {
    id        String   @id @default("default")
    // Colors
    primaryColor       String @default("#2563eb")
    secondaryColor     String @default("#0ea5e9")
    accentColor        String @default("#8b5cf6")
    backgroundColor    String @default("#f8f9fc")
    textColor          String @default("#0f172a")
    colorSettings      Json?
    // Theme Mode
    themeMode          String @default("light")
    // Session Settings (for main Admin)
    sessionTimeoutMin  Int    @default(10)  // Default 10 minutes
    maxSessions        Int    @default(2)
    // Hero Section
    heroTitle          String @default("Master Computer Skills")
    heroSubtitle       String @default("Practical, job-ready computer education for every student in India.")
    heroCtaText        String @default("Start Learning")
    // Stats
    statsStudentsCount String @default("40K+")
    statsRating        String @default("4.7")
    statsMonthly       String @default("150K+")
    // Footer
    footerCopyright    String @default("© 2026 WEBCOM. All Rights Reserved. Made with ❤️ in India")
    // Social Links
    googleReviewUrl    String @default("")
    // Storage Configuration
    storageProvider    String @default("local")  // "local" | "s3" | "r2" | "gcs"
    storageConfig      Json?  // { bucket, region, accessKeyId, secretAccessKey, endpoint, accountId, projectId, credentials }
    updatedAt          DateTime @updatedAt
    createdAt          DateTime @default(now())
}
