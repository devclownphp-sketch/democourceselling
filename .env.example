# ==========================================
# DATABASE - Get from Neon (neon.tech)
# ==========================================
DATABASE_URL=postgresql://username:password@ep-xxx.neon.tech/dbname?sslmode=require

# ==========================================
# AUTH - Generate secret at: https://1password.com/password-generator
# ==========================================
NEXTAUTH_SECRET=your-super-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# ==========================================
# PUBLIC
# ==========================================
NEXT_PUBLIC_GOOGLE_REVIEW_URL=https://www.google.com/maps/place/WEBCOM

# ==========================================
# ADMIN LOGIN (Main Admin - Superuser)
# ==========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here

# ==========================================
# AWS S3 (Optional - for PDF storage)
# ==========================================
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=ap-southeast-1
# AWS_S3_BUCKET=your-bucket-name

# ==========================================
# STORAGE PROVIDER
# ==========================================
# local  - Store files on local filesystem (default for localhost)
# s3     - Use AWS S3 for file storage
# r2     - Use Cloudflare R2 for file storage
# gcs    - Use Google Cloud Storage
# ==========================================
STORAGE_PROVIDER=local

# Cloudflare R2 (when STORAGE_PROVIDER=r2)
# CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
# CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=your-r2-bucket-name
# AWS_REGION=auto

# ==========================================
# SESSION SETTINGS
# ==========================================
# Max concurrent sessions per admin
# ADMIN_MAX_SESSIONS=2
# Default session timeout in minutes
# DEFAULT_SESSION_TIMEOUT=30
